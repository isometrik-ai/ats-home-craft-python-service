# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_KEY=

# Postgres (via Supabase)
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USER=
DB_PASSWORD=

# SigNoz / OpenTelemetry (API monitoring)
# ENABLE_TELEMETRY=true
# SIGNOZ_SERVICE_NAME=legalai-user-service
# SERVICE_VERSION=1.0.0
# SIGNOZ_ENVIRONMENT=development

# SigNoz Cloud
# SIGNOZ_CLOUD_URL=https://ingest.<region>.signoz.cloud
# SIGNOZ_CLOUD_TOKEN=<your-ingestion-key>

# Self-hosted SigNoz (gRPC)
# SIGNOZ_ENDPOINT=signoz-otel-collector:4317

# Disable telemetry locally
# ENABLE_TELEMETRY=false

# Graphiti / FalkorDB (org memory) — uses OPENAI_API_KEY above
# GRAPHITI_ENABLED=true
# GRAPHITI_CONSUMER_GROUP_ID=crm-graphiti-sync
# GRAPHITI_DLQ_TOPIC=crm.graphiti.dlq.dev
# GRAPHITI_SYNC_MAX_RETRIES=3
# GRAPHITI_SYNC_RETRY_BASE_DELAY_SECONDS=0.5
# GRAPHITI_SYNC_TIMEOUT_SECONDS=60
# GRAPHITI_CONSUMER_MAX_CONCURRENCY=4
# GRAPHITI_STRICT_INDEX_VERIFY=false
# GRAPHITI_CRM_EVENTS_TOPIC=crm.events.dev
# GRAPHITI_STARTUP_BACKFILL_ENABLED=false
# GRAPHITI_STARTUP_BACKFILL_LIMIT=500
# GRAPHITI_STARTUP_BACKFILL_MODE=pending
# KAFKA_ENABLED=true
