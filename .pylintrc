[MASTER]
# Extensions for better analysis
load-plugins=
    pylint.extensions.docparams,
    pylint.extensions.docstyle,
    pylint.extensions.mccabe,
    pylint.extensions.typing

# Allow C-extensions (e.g., pydantic) to be treated as typed
extension-pkg-allow-list=pydantic

# Optimize performance for large projects
unsafe-load-any-extension=no  # More secure setting

# Python version
py-version=3.13

# Files or directories to ignore
ignore=CVS,.git,__pycache__,venv,htmlcov,build
ignore-patterns=

# Keep information between runs
persistent=yes

# Number of processes to use for static checking
jobs=4

# Add project roots to pylint's Python path
init-hook='import sys; sys.path.extend(["apps", "libs"])'

[MESSAGES CONTROL]
# Disable messages that are not relevant for your FastAPI project
disable=
    ; C0111,  # missing-docstring
    ; C0103,  # invalid-name
    C0303,  # trailing-whitespace
    W0311,  # bad-indentation
    ; W0603,  # global-statement
    W0621,  # redefined-outer-name
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    E1136,  # unsubscriptable-object (for SQLAlchemy Mapped types)
    # FastAPI specific
    E1101,  # no-member (for Pydantic models)
    W0718,  # broad-exception-caught (common in FastAPI error handlers)
    C0415,  # import-outside-toplevel (sometimes needed in FastAPI dependencies)
    W0212,  # protected-access (common when using ORMs)
    E0213,  # no-self-argument (for FastAPI dependency functions)
    W0221,  # arguments-differ (common with inheritance in Pydantic)
    R0801,  # duplicate-code (FastAPI route handlers often have similar patterns)
    E1102,  # not-callable (for SQLAlchemy func methods)
    # C0412,  # ungrouped-imports (FastAPI often needs conditional imports)
    # R0401,  # cyclic-imports (common with pydantic model references)
    # W1203,  # logging-fstring-interpolation (modern practice with logging)
    # C0302,  # too-many-lines (routers can get large in well-structured apps)
    # R0902,  # too-many-instance-attributes (common for Pydantic models)

[REPORTS]
# Output format
output-format=text

# Reports enabled/disabled
reports=no

# Evaluation formula
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[BASIC]
# Good variable names which should always be accepted
# i,j,k: Loop counters
# ex: Exception variable
# _: Unused variable
# id, pk: Database identifiers
# db: Database connection
# e: Exception variable
# x,y,z: Coordinates
# ip: IP address
# fn: Function reference
# qs: Query string/QuerySet
# f: File handle
# to: Timeout
# kw: Keyword arguments
# dt: Datetime
# tx: Transaction
good-names=i,j,k,ex,Run,_,id,db,e,x,y,z,ip,pk,fn,qs,f,to,kw,dt,tx,io,ok

# Bad variable names which should always be refused
bad-names=foo,bar,baz,toto,tutu,tata

# Include naming hint in the error message
include-naming-hint=yes

# Regular expressions for various name types
function-rgx=[a-z_][a-z0-9_]{2,50}$
variable-rgx=[a-z_][a-z0-9_]{2,50}$
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__))$
attr-rgx=[a-z_][a-z0-9_]{2,50}$
argument-rgx=[a-z_][a-z0-9_]{2,50}$
class-attribute-rgx=([A-Za-z_][A-Za-z0-9_]{2,50}|(__.*__))$
inlinevar-rgx=[A-Za-z_][A-Za-z0-9_]*$
class-rgx=[A-Z_][a-zA-Z0-9]+$
module-rgx=(([a-z_][a-z0-9_]*)|([A-Z][a-zA-Z0-9]+))$
method-rgx=[a-z_][a-z0-9_]{2,50}$

# Regular expression which should only match function or class names that do not need docstrings
no-docstring-rgx=__.*__

# Minimum line length for functions/classes that require docstrings
docstring-min-length=-1

[FORMAT]
# Maximum line length
max-line-length=100

# Ignore long lines that match a regex
ignore-long-lines=^\s*(# )?<?https?://\S+>?$

# Allow the body of an if to be on the same line as the test if there is no else
single-line-if-stmt=no

# Maximum number of line characters
max-module-lines=2000

# String used as indentation
indent-string='    '

# Expected format of line ending (can be empty for auto-detection)
expected-line-ending-format=

[MISCELLANEOUS]
# List of note tags to take into consideration
notes=FIXME,TODO,XXX,HACK

[SIMILARITIES]
# Minimum similarity lines between two sections of code
min-similarity-lines=6

# Ignore comments when computing similarities
ignore-comments=yes

# Ignore docstrings when computing similarities
ignore-docstrings=yes

# Ignore imports when computing similarities
ignore-imports=no

# Additional directories to ignore
ignore-paths=
    ^migrations/.*$
    ^alembic/.*$
    ^docs/.*$

[TYPECHECK]
# Tells whether missing members are treated as class attributes
ignore-mixin-members=yes

# Classes that should be ignored for type checking
ignored-classes=
    SQLObject,
    SQLAlchemy,
    scoped_session,
    Session,
    Base,
    Query


# Generated members that should be considered valid
generated-members=
    REQUEST,
    acl_users,
    aq_parent,
    objects,
    DoesNotExist,
    request,
    response,
    session,
    query,
    commit,
    rollback,
    execute,
    scalar,
    first,
    all,
    delete,
    .*_set,
    id,
    pk,
    .*_id

# Tells whether we should check for unused import in __init__ files
init-import=no

[VARIABLES]
# A regular expression matching the name of dummy variables
dummy-variables-rgx=_$|dummy

# List of additional names supposed to be defined in builtins
additional-builtins=

[CLASSES]
# List of method names used to declare instance attributes
defining-attr-methods=
    __init__,
    __new__,
    setUp

# List of valid names for the first argument in a class method
valid-classmethod-first-arg=cls

# List of valid names for the first argument in a metaclass class method
valid-metaclass-classmethod-first-arg=mcs

[DESIGN]
# Maximum number of arguments for a function/method
max-args=8

# Maximum number of positional arguments for a function call
max-positional-arguments=8

# Argument names that should not count toward the maximum
ignored-argument-names=_.*

# Maximum number of locals for function/method
max-locals=20

# Maximum number of return statements for function/method
max-returns=8

# Maximum number of branch statements for function/method
max-branches=15

# Maximum number of statements in function/method
max-statements=50

# Maximum number of parents for a class
max-parents=8

# Maximum number of attributes for a class
max-attributes=15

# Minimum number of public methods for a class
min-public-methods=0

# Maximum number of public methods for a class
max-public-methods=20

[IMPORTS]
# Deprecated modules which should not be used
deprecated-modules=
    regsub,TERMIOS,
    Bastion,
    rexec

[EXCEPTIONS]
# Use fully qualified exception names
overgeneral-exceptions=
    builtins.Exception,
    builtins.BaseException,
    builtins.StandardError  # Only for Python 2 compatibility
